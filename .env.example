# =============================================================================
# controle-credito - environment example
# Copy to .env (gitignored) and fill in real values.
# =============================================================================

# --- Node / runtime ---
NODE_ENV=development
PORT_API=3001
PORT_WEB=3000
LOG_LEVEL=debug

# --- Database (Postgres 18) ---
# dev: postgres://app:app@localhost:5432/controle_credito
DATABASE_URL=postgres://app:app@localhost:5432/controle_credito
DATABASE_URL_TEST=postgres://app:app@localhost:5432/controle_credito_test

# --- Redis (Upstash in prod, local docker in dev) ---
REDIS_URL=redis://localhost:6379

# --- Auth (NextAuth v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-32-bytes-base64
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=change-me-32-bytes-base64

# --- Recovery providers (Sprint 2; stubs in Sprint 1) ---
EMAIL_PROVIDER_API_KEY=
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_FROM=

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_ENVIRONMENT=development
