# =============================================================================
# controle-credito - environment example
# Copy to .env (gitignored) and fill in real values.
# =============================================================================

# --- Node / runtime ---
NODE_ENV=development
PORT_API=3001
PORT_WEB=3000
LOG_LEVEL=debug

# --- Database (Postgres 18) ---
# dev: postgres://app:app@localhost:5432/controle_credito
DATABASE_URL=postgres://app:app@localhost:5432/controle_credito
DATABASE_URL_TEST=postgres://app:app@localhost:5432/controle_credito_test

# --- Redis (Upstash in prod, local docker in dev) ---
REDIS_URL=redis://localhost:6379

# --- Auth (NextAuth v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-32-bytes-base64
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=change-me-32-bytes-base64
# Refresh token TTL in hours (access token fixed at 15min). Default 12h.
SESSION_TTL_HOURS=12

# --- Recovery providers (Sprint 2; stubs in Sprint 1) ---
EMAIL_PROVIDER_API_KEY=
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_FROM=

# --- Observabilidade ---

# Sentry (error monitoring + tracing). Sem SENTRY_DSN, fica noop.
# SENTRY_DSN: server-side (apps/api)
# NEXT_PUBLIC_SENTRY_DSN: client/browser + server SSR + edge (apps/web).
#   Mesmo valor nas duas - DSN eh' publico, apenas identifica o projeto.
# tracesSampleRate: 0 = nenhum trace, 1 = todos. 0.1 (10%) eh' o padrao Sentry.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# CI only (para upload de source maps durante build de prod):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# OpenTelemetry traces (server-side). Sem endpoint, OTel roda mas nao
# exporta.
OTEL_EXPORTER_OTLP_ENDPOINT=
