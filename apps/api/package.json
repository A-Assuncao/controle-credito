{
  "name": "@controle-credito/api",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch --tsconfig=tsconfig.dev.json --env-file=../../.env src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src test --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node --env-file=../../.env scripts/run-e2e.js"
  },
  "dependencies": {
    "@controle-credito/contracts": "workspace:*",
    "@controle-credito/domain": "workspace:*",
    "@controle-credito/infra": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "jose": "^5.9.4",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.4"
  }
}
