{
  "name": "controle-credito",
  "version": "0.5.0-code",
  "private": true,
  "description": "SaaS de gestao de emprestimos pessoais (Brasil). Monorepo: NestJS API + Next.js web.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "commitlint": "commitlint --edit",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "@humanwhocodes/config-array": "npm:@eslint/config-array@^0.23.5",
      "@humanwhocodes/object-schema": "npm:@eslint/object-schema@^3.0.5",
      "otplib": "^13.4.1"
    }
  }
}
